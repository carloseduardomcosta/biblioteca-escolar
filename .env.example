# Copie para .env e preencha. NUNCA versione o .env real.

# ── Banco de dados MySQL ──
MYSQL_ROOT_PASSWORD=troque-esta-senha-root
MYSQL_DATABASE=biblioteca
MYSQL_USER=biblioteca
MYSQL_PASSWORD=troque-esta-senha

# ── Flask ──
# Chave que assina os cookies de sessão. Gere uma forte:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=gere-uma-chave-longa-e-aleatoria

# Liga o log de SQL do SQLAlchemy (0 = desligado, recomendado em produção)
SQL_ECHO=0

# ── Cloudflare (OPCIONAL) ──
# Só é necessário se você automatizar o registro DNS via API.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_EMAIL=
